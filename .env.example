# Chuỗi kết nối Postgres (Neon). Khi deploy qua Vercel, chọn Storage → Postgres
# thì các biến DATABASE_URL / DATABASE_URL_UNPOOLED sẽ được tự động điền.
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# Tự động có khi kết nối Vercel Blob (Storage → Blob) — không cần tự điền.
BLOB_READ_WRITE_TOKEN=""

# Admin panel
# Tạo mật khẩu mới: npm run hash-password -- "mat-khau-cua-ban"
# rồi dán chuỗi hash in ra vào ADMIN_PASSWORD_HASH bên dưới.
# QUAN TRỌNG: thêm dấu \ trước mỗi dấu $ trong chuỗi hash (vd \$2b\$10\$...)
# để Next.js không hiểu nhầm $2b/$10 là biến môi trường khác.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH=""
SESSION_SECRET="doi-thanh-mot-chuoi-ngau-nhien-it-nhat-32-ky-tu"
